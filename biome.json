{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "includes": ["src/**", "scripts/**", "tests-fixtures/**"] },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "single" }
  },
  "css": {
    "parser": { "tailwindDirectives": true }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "warn",
        "noAssignInExpressions": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/engine/**", "src/data5e/**", "src/dice/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "react": "engine/data5e/dice must stay React-free (architecture boundary)",
                  "react-dom": "engine/data5e/dice must stay React-free (architecture boundary)"
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/data5e/entries/**", "src/data5e/hooks.ts"],
      "linter": {
        "rules": {
          "style": { "noRestrictedImports": "off" }
        }
      }
    }
  ]
}
